generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String    @id @default(cuid())
  email                     String    @unique
  password                  String
  name                      String
  role                      String    @default("doctora")
  emailVerifiedAt           DateTime?
  emailVerifyTokenHash      String?
  emailVerifyTokenExpiresAt DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  appointments Appointment[] @relation("UserAppointments")
}

model Patient {
  id                    String   @id @default(cuid())
  fullName              String
  dni                   String   @unique
  phone                 String
  address               String
  birthDate             DateTime
  emergencyContactName  String?
  emergencyContactPhone String?
  allergyNotes          String?
  medicalHistory        String?
  referralSource        String?
  status                String   @default("estable")
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  appointments  Appointment[]
  clinicalNotes ClinicalNote[]
  recipes       Recipe[]
}

model Appointment {
  id        String   @id @default(cuid())
  patientId String
  doctorId  String
  startAt   DateTime
  endAt     DateTime
  type      String
  status    String   @default("pendiente")
  reason    String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient       Patient        @relation(fields: [patientId], references: [id])
  doctor        User           @relation("UserAppointments", fields: [doctorId], references: [id])
  clinicalNotes ClinicalNote[]
  recipes       Recipe[]
}

model ClinicalNote {
  id            String   @id @default(cuid())
  patientId     String
  appointmentId String?
  historyNumber Int      @unique @default(autoincrement())
  createdAt     DateTime @default(now())

  identificationExtra String?
  personalHistory     String?
  familyHistory       String?
  consultationReason  String?
  currentIllness      String?
  physicalExam        String?
  diagnostics         String?
  diagnosis           String?
  treatmentPlan       String?
  evolutionNotes      String?

  patient     Patient      @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
}

model Recipe {
  id            String  @id @default(cuid())
  patientId     String
  appointmentId String?

  recipeNumber Int      @unique @default(autoincrement())
  createdAt    DateTime @default(now())

  diagnosis        String?
  workPlan         String?
  prescriptionText String?

  patient     Patient      @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
}
