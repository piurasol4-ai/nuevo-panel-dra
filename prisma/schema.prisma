generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String    @id @default(cuid())
  email                     String    @unique
  password                  String
  name                      String
  role                      String    @default("doctora")
  emailVerifiedAt           DateTime?
  emailVerifyTokenHash      String?
  emailVerifyTokenExpiresAt DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  appointments Appointment[] @relation("UserAppointments")
}

model Patient {
  id                    String   @id @default(cuid())
  fullName              String
  documentType          String   @default("dni")
  dni                   String
  phone                 String
  address               String
  birthDate             DateTime
  emergencyContactName  String?
  emergencyContactPhone String?
  allergyNotes          String?
  medicalHistory        String?
  referralSource        String?
  status                String   @default("estable")
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  appointments  Appointment[]
  clinicalNotes ClinicalNote[]
  recipes       Recipe[]
  ticketRecords TicketRecord[]

  @@unique([documentType, dni])
}

model Appointment {
  id        String   @id @default(cuid())
  patientId String
  doctorId  String
  startAt   DateTime
  endAt     DateTime
  type      String
  status    String   @default("pendiente")
  reason    String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient       Patient        @relation(fields: [patientId], references: [id])
  doctor        User           @relation("UserAppointments", fields: [doctorId], references: [id])
  clinicalNotes ClinicalNote[]
  recipes       Recipe[]
  ticketRecord  TicketRecord?
}

model ClinicalNote {
  id            String   @id @default(cuid())
  patientId     String
  appointmentId String?
  historyNumber Int      @unique @default(autoincrement())
  createdAt     DateTime @default(now())

  // Una sola historia por paciente, pero con múltiples atenciones/fichas
  // almacenadas como arreglo en JSON.
  visits        Json?

  // --- Ficha de atención (por visita) ---
  identificationExtra String?
  personalHistory     String?
  familyHistory       String?
  consultationReason  String?
  currentIllness      String?
  physicalExam        String?
  diagnostics         String?
  diagnosis           String?
  treatmentPlan       String?
  evolutionNotes      String?

  // Campos extra solicitados por cada atención/ficha
  nursingNotes         String? // Notas de Enfermería
  treatmentNotes       String? // Notas de tratamiento
  weight               String? // Peso (unidades libres, p.ej. "72 kg")
  height               String? // Talla (p.ej. "1.68 m")
  bodyTemperature      String? // Temperatura corporal (p.ej. "36.7 °C")
  bloodPressure        String? // Presión arterial (p.ej. "120/80")
  oxygenSaturation     String? // Saturación (p.ej. "98%")
  heartRate            String? // Frecuencia cardíaca (p.ej. "72 lpm")
  respiratoryRate      String? // Frecuencia respiratoria (p.ej. "18 rpm")
  glucose              String? // Glucosa (p.ej. "95 mg/dL")

  patient     Patient      @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
}

model Recipe {
  id            String  @id @default(cuid())
  patientId     String
  appointmentId String?

  recipeNumber Int      @unique @default(autoincrement())
  createdAt    DateTime @default(now())

  diagnosis        String?
  workPlan         String?
  prescriptionText String?

  patient     Patient      @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
}

// ---- Catálogos y ventas (en DB para evitar inconsistencias por localStorage) ----
model ProcedurePrice {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  priceCents Int    // Precio unitario en céntimos (para evitar floats)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductCatalog {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  category   String
  use        String
  stock      Int      @default(0)
  unitPriceCents Int  // Precio unitario en céntimos
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ticketLines TicketLine[]
}

model TicketRecord {
  id        String   @id @default(cuid())
  ticketNumber Int   @unique @default(autoincrement())
  createdAt DateTime @default(now())

  // Fecha en formato yyyy-mm-dd (para filtrar fácil por día en UI)
  dateISO   String

  appointmentId String? @unique
  patientId String
  patientName String
  patientDni String

  procedureName String
  procedureUnitPriceCents Int

  paymentEfectivoCents Int @default(0)
  paymentYapeCents Int @default(0)
  paymentPlinCents Int @default(0)
  paymentTransferenciaCents Int @default(0)
  paymentTotalCents Int @default(0)

  totalCents Int

  ticketLines TicketLine[]

  // Opcionales para relacionar (por integridad; la UI no depende de esto)
  patient Patient @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
}

model TicketLine {
  id Int @id @default(autoincrement())
  ticketId String

  // Si viene de un producto catálogo, productId es un Int; si es "extra", va null.
  productId Int?

  name String
  quantity Int
  unitPriceCents Int
  lineTotalCents Int

  ticket TicketRecord @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  product ProductCatalog? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([ticketId])
}
