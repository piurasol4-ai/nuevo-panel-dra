generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String    @id @default(cuid())
  email                     String    @unique
  password                  String
  name                      String
  role                      String    @default("doctora")
  emailVerifiedAt           DateTime?
  emailVerifyTokenHash      String?
  emailVerifyTokenExpiresAt DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  appointments Appointment[] @relation("UserAppointments")
}

model Patient {
  id                    String   @id @default(cuid())
  fullName              String
  dni                   String   @unique
  phone                 String
  address               String
  birthDate             DateTime
  emergencyContactName  String?
  emergencyContactPhone String?
  allergyNotes          String?
  medicalHistory        String?
  referralSource        String?
  status                String   @default("estable")
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  appointments  Appointment[]
  clinicalNotes ClinicalNote[]
  recipes       Recipe[]
}

model Appointment {
  id        String   @id @default(cuid())
  patientId String
  doctorId  String
  startAt   DateTime
  endAt     DateTime
  type      String
  status    String   @default("pendiente")
  reason    String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient       Patient        @relation(fields: [patientId], references: [id])
  doctor        User           @relation("UserAppointments", fields: [doctorId], references: [id])
  clinicalNotes ClinicalNote[]
  recipes       Recipe[]
}

model ClinicalNote {
  id            String   @id @default(cuid())
  patientId     String
  appointmentId String?
  historyNumber Int      @unique @default(autoincrement())
  createdAt     DateTime @default(now())

  // Una sola historia por paciente, pero con múltiples atenciones/fichas
  // almacenadas como arreglo en JSON.
  visits        Json?

  // --- Ficha de atención (por visita) ---
  identificationExtra String?
  personalHistory     String?
  familyHistory       String?
  consultationReason  String?
  currentIllness      String?
  physicalExam        String?
  diagnostics         String?
  diagnosis           String?
  treatmentPlan       String?
  evolutionNotes      String?

  // Campos extra solicitados por cada atención/ficha
  nursingNotes         String? // Notas de Enfermería
  treatmentNotes       String? // Notas de tratamiento
  weight               String? // Peso (unidades libres, p.ej. "72 kg")
  height               String? // Talla (p.ej. "1.68 m")
  bodyTemperature      String? // Temperatura corporal (p.ej. "36.7 °C")
  bloodPressure        String? // Presión arterial (p.ej. "120/80")
  oxygenSaturation     String? // Saturación (p.ej. "98%")
  heartRate            String? // Frecuencia cardíaca (p.ej. "72 lpm")
  respiratoryRate      String? // Frecuencia respiratoria (p.ej. "18 rpm")
  glucose              String? // Glucosa (p.ej. "95 mg/dL")

  patient     Patient      @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
}

model Recipe {
  id            String  @id @default(cuid())
  patientId     String
  appointmentId String?

  recipeNumber Int      @unique @default(autoincrement())
  createdAt    DateTime @default(now())

  diagnosis        String?
  workPlan         String?
  prescriptionText String?

  patient     Patient      @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
}
